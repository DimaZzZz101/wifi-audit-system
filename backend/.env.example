# Database (default for Docker Compose)
DATABASE_URL=postgresql+asyncpg://wifiaudit:wifiaudit@db:5432/wifiaudit

# For local dev with PostgreSQL on host
# DATABASE_URL=postgresql+asyncpg://wifiaudit:wifiaudit@localhost:5432/wifiaudit

# Auth (тот же SECRET_KEY должен быть в TOOL-manager)
SECRET_KEY=replace-with-openssl-rand-hex-32

# TOOL-manager (для локальной разработки Gateway)
# TOOL_MANAGER_URL=http://localhost:8001

# cAdvisor (метрики хоста и контейнеров; список системных - из TOOL-manager)
# CADVISOR_URL=http://localhost:8080

# Plugins / Modules
# PLUGINS_DIR=./plugins
# ARTIFACTS_DIR=./artifacts
# Каталог доступных модулей (JSON): [ { "id", "name", "version", "download_url", "checksum?" } ]
# MODULES_INDEX_URL=https://example.com/modules/index.json
# Базовый URL для скачивания, если в каталоге указаны относительные пути
# MODULES_DOWNLOAD_BASE_URL=https://example.com/modules/packages

# Optional
# DEBUG=false
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
